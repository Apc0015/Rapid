# ============================================
# RAPID Environment Configuration
# ============================================

# Deployment environment
RAPID_ENV=development

# FastAPI settings
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
REQUEST_TIMEOUT=120
MAX_FILE_UPLOAD_SIZE=104857600

# ============================================
# Authentication & Security (REQUIRED)
# ============================================
JWT_SECRET_KEY=your-strong-random-secret-key-here-minimum-32-characters

# ============================================
# LLM Configuration (choose one primary provider)
# ============================================

# PRIMARY: OpenRouter (100+ models)
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o-mini

# FALLBACK: Local Ollama (free, no API key needed)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama2

# Optional: Anthropic Claude
ANTHROPIC_API_KEY=

# Optional: OpenAI
OPENAI_API_KEY=

# ============================================
# Database Configuration (Optional)
# ============================================
# Defaults to SQLite at data/db/rapid.db
# For PostgreSQL: DATABASE_URL=postgresql://user:pass@localhost:5432/rapid
DATABASE_URL=sqlite:///data/db/rapid.db

# ============================================
# Vector Store Configuration (Optional)
# ============================================
# Defaults to FAISS
USE_QDRANT=false
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ============================================
# Optional: Web Search
# ============================================
SERPER_API_KEY=

# ============================================
# Optional: Cloud Integrations
# ============================================

# Microsoft OneDrive (OAuth2 PKCE)
MICROSOFT_CLIENT_ID=
MICROSOFT_REDIRECT_URI=http://localhost:8000/cloud/onedrive/callback

# Google Gmail (OAuth2)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/cloud/gmail/callback

# Google Drive (OAuth2 — reuses same GOOGLE_CLIENT_ID + GOOGLE_CLIENT_SECRET as Gmail)
GOOGLE_DRIVE_REDIRECT_URI=http://localhost:8000/cloud/gdrive/callback

# GitHub (optional — required only for private repos)
# Generate at: https://github.com/settings/tokens (needs repo scope)
GITHUB_TOKEN=

# Frontend base URL (used by OAuth callbacks to redirect after connect)
FRONTEND_BASE_URL=http://localhost

# ============================================
# Logging & Monitoring
# ============================================
LOG_LEVEL=INFO
AUDIT_LOG_PATH=data/audit.log
AUDIT_RETENTION_DAYS=2555

# ============================================
# Development Only
# ============================================
# Set to true to enable detailed logging and auto-reload
DEBUG=false
