# ============================================
# RAPID Environment Configuration
# ============================================

# Deployment environment
RAPID_ENV=development
# Set true only for a deliberately exposed synthetic demo environment.
RAPID_ENABLE_DEMO=false
# Bounded latency budget for interactive organization-wide intelligence requests.
RAPID_ORGANIZATION_AI_TIMEOUT_SECONDS=12

# FastAPI settings
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4173,http://127.0.0.1:4173
REQUEST_TIMEOUT=120
MAX_FILE_UPLOAD_SIZE=104857600

# ============================================
# Authentication & Security (REQUIRED)
# ============================================
JWT_SECRET_KEY=your-strong-random-secret-key-here-minimum-32-characters
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
RAPID_ENCRYPTION_KEY=
ALLOWED_HOSTS=app.example.com
RAPID_MAX_REQUEST_BYTES=26214400

# ============================================
# LLM Configuration (choose one primary provider)
# ============================================

# PRIMARY: OpenRouter (100+ models)
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small

# FALLBACK: Local Ollama (free, no API key needed)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.2
# Docker Compose uses http://ollama:11434/v1 by default. Override only for a remote Ollama service.
OLLAMA_DOCKER_BASE_URL=

# Optional: Anthropic Claude
ANTHROPIC_API_KEY=

# Optional: OpenAI
OPENAI_API_KEY=

# ============================================
# Database Configuration (Optional)
# ============================================
# Defaults to SQLite at data/db/rapid.db
# For PostgreSQL: DATABASE_URL=postgresql://user:pass@localhost:5432/rapid
DATABASE_URL=sqlite:///data/db/rapid.db

# ============================================
# Vector Store Configuration (Optional)
# ============================================
# Defaults to FAISS
USE_QDRANT=false
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Durable jobs and connector processing
RAPID_JOB_DB_PATH=data/db/jobs.db
RAPID_ENABLE_JOB_WORKER=false
# Set true in any deployment that relies on a separate durable worker.
RAPID_REQUIRE_JOB_WORKER=false
RAPID_ENABLE_SCHEDULER=false
RAPID_JOB_POLL_SECONDS=1
RAPID_PII_MODE=redact
RAPID_ALLOW_UNSIGNED_SANDBOX_WEBHOOKS=true

# ============================================
# Optional: Web Search
# ============================================
SERPER_API_KEY=

# ============================================
# Optional: Cloud Integrations
# ============================================

# Microsoft OneDrive (OAuth2 PKCE)
MICROSOFT_CLIENT_ID=
MICROSOFT_REDIRECT_URI=http://localhost:8000/cloud/onedrive/callback

# Google Gmail (OAuth2)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/cloud/gmail/callback

# Google Drive (OAuth2 — reuses same GOOGLE_CLIENT_ID + GOOGLE_CLIENT_SECRET as Gmail)
GOOGLE_DRIVE_REDIRECT_URI=http://localhost:8000/cloud/gdrive/callback

# Legacy direct cloud connector routes bypass the governed tenant connector path.
# Leave disabled for normal startup and production deployments.
RAPID_ENABLE_LEGACY_CLOUD_CONNECTORS=false

# GitHub (optional — required only for private repos)
# Generate at: https://github.com/settings/tokens (needs repo scope)
GITHUB_TOKEN=

# Frontend base URL (used by OAuth callbacks to redirect after connect)
FRONTEND_BASE_URL=http://localhost
# React portal URL used by the API root and retired legacy console redirects.
RAPID_PORTAL_URL=http://127.0.0.1:4173

# Private beta access. In production, only these account IDs can review beta
# applications and issue one-time activation links. Comma-separated values.
RAPID_BETA_REVIEWER_IDS=your_admin_user_id
RAPID_BETA_DB_PATH=data/db/beta_access.db
# Keep old public provisioning and department-registration APIs closed during
# private beta. They remain available in development for migration tests.
RAPID_ALLOW_SELF_SERVICE_PROVISIONING=false
RAPID_ALLOW_LEGACY_REGISTRATION=false

# ============================================
# Logging & Monitoring
# ============================================
LOG_LEVEL=INFO
AUDIT_LOG_PATH=data/audit.log
AUDIT_RETENTION_DAYS=2555

# ============================================
# Development Only
# ============================================
# Set to true to enable detailed logging and auto-reload
DEBUG=false
